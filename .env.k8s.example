# Atlas MCP Kubernetes Environment Configuration

# ==============================================================================
# БАЗОВІ НАЛАШТУВАННЯ
# ==============================================================================

# Середовище розгортання (development/production)
ATLAS_ENVIRONMENT=development

# Namespace для Kubernetes
ATLAS_NAMESPACE=atlas-mcp-dev

# Registry для Docker образів (встановіть свій)
DOCKER_REGISTRY=localhost:5000
# DOCKER_REGISTRY=your-registry.com
# DOCKER_REGISTRY=ghcr.io/your-username

# ==============================================================================
# ATLAS CORE НАЛАШТУВАННЯ
# ==============================================================================

# Хост та порт для веб-сервера
ATLAS_WEB_HOST=0.0.0.0
ATLAS_WEB_PORT=8000

# Рівень логування (DEBUG/INFO/WARNING/ERROR)
ATLAS_LOG_LEVEL=INFO

# Директорія для даних
ATLAS_DATA_DIR=/app/data

# ==============================================================================
# LLM НАЛАШТУВАННЯ
# ==============================================================================

# Ollama URL
OLLAMA_URL=http://host.docker.internal:11434

# Використовувати вбудований Ollama
USE_EMBEDDED_OLLAMA=false

# LLM провайдер
ATLAS_LLM_PROVIDER=ollama

# LLM моделі
ATLAS_LLM1_MODEL=llama3.1:8b
ATLAS_LLM2_MODEL=gpt-oss:latest
ATLAS_LLM3_MODEL=llama3.1:8b

# ==============================================================================
# MCP СЕРВІСИ
# ==============================================================================

# Список MCP серверів
ATLAS_MCP_SERVERS=automation,macos-automator,tts,playwright

# MCP URLs (встановлюються автоматично в Kubernetes)
ATLAS_MCP_TTS_URL=http://mcp-tts-service:4004
ATLAS_MCP_PLAYWRIGHT_URL=http://mcp-playwright-service:4005/mcp

# ==============================================================================
# TTS НАЛАШТУВАННЯ
# ==============================================================================

# TTS провайдери
TTS_PROVIDERS=ukrainian_tts,google_tts
TTS_DEFAULT_PROVIDER=ukrainian_tts

# Google TTS API ключ (встановіть в secrets)
GOOGLE_TTS_API_KEY=

# Мова для TTS
GOOGLE_TTS_LANGUAGE=uk
ATLAS_TTS_LANG=uk

# Директорія для TTS файлів
TTS_OUTPUT_DIR=/data/tts

# Налаштування Ukrainian TTS
UK_TTS_DEVICE=cpu
UK_TTS_PREFERRED_FORMAT=wav

# ==============================================================================
# АВТОМАТИЗАЦІЯ
# ==============================================================================

# Порт для MCP Automation
MCP_AUTOMATION_PORT=4002
AUTOMATION_LOG_LEVEL=INFO

# Порт для MCP Automator
MCP_AUTOMATOR_PORT=4003
MACOS_AUTOMATOR_ENABLED=true

# ==============================================================================
# БАЗИ ДАНИХ
# ==============================================================================

# Redis налаштування
REDIS_HOST=redis-service
REDIS_PORT=6379

# Qdrant налаштування
QDRANT_HOST=qdrant-service
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# ==============================================================================
# МОНІТОРИНГ
# ==============================================================================

# Prometheus налаштування
PROMETHEUS_RETENTION_TIME=30d
PROMETHEUS_RETENTION_SIZE=10GB

# Grafana налаштування
GRAFANA_ADMIN_PASSWORD=atlas_admin

# Включити моніторинг
ENABLE_MONITORING=true

# ==============================================================================
# БЕЗПЕКА
# ==============================================================================

# Секретний ключ для сеансів
SECRET_KEY=changeme-in-production

# Включити HTTPS
ENABLE_HTTPS=true

# Домени для SSL сертифікатів
ATLAS_DOMAIN=atlas.local
ATLAS_API_DOMAIN=api.atlas.local

# ==============================================================================
# KUBERNETES НАЛАШТУВАННЯ
# ==============================================================================

# Кількість реплік для development
ATLAS_CORE_REPLICAS=2
ATLAS_FRONTEND_REPLICAS=3
MCP_AUTOMATION_REPLICAS=2
MCP_AUTOMATOR_REPLICAS=2
MCP_TTS_REPLICAS=2
MCP_PLAYWRIGHT_REPLICAS=2

# Ресурси для development (requests)
ATLAS_CORE_CPU_REQUEST=250m
ATLAS_CORE_MEMORY_REQUEST=512Mi
ATLAS_FRONTEND_CPU_REQUEST=100m
ATLAS_FRONTEND_MEMORY_REQUEST=256Mi

# Ресурси для development (limits)
ATLAS_CORE_CPU_LIMIT=1000m
ATLAS_CORE_MEMORY_LIMIT=2Gi
ATLAS_FRONTEND_CPU_LIMIT=500m
ATLAS_FRONTEND_MEMORY_LIMIT=1Gi

# ==============================================================================
# ЗБЕРІГАННЯ
# ==============================================================================

# StorageClass для PVC
STORAGE_CLASS=fast-ssd

# Розміри зберігання для development
ATLAS_DATA_SIZE=10Gi
ATLAS_LOGS_SIZE=5Gi
REDIS_DATA_SIZE=5Gi
QDRANT_DATA_SIZE=20Gi
PROMETHEUS_DATA_SIZE=15Gi
GRAFANA_DATA_SIZE=5Gi
TTS_AUDIO_SIZE=10Gi

# ==============================================================================
# INGRESS
# ==============================================================================

# Ingress класс
INGRESS_CLASS=nginx

# Включити SSL переадресацію
SSL_REDIRECT=true

# Розмір тіла запиту
PROXY_BODY_SIZE=100m

# Таймаути
PROXY_READ_TIMEOUT=300
PROXY_SEND_TIMEOUT=300
PROXY_CONNECT_TIMEOUT=300

# Rate limiting
RATE_LIMIT=100
RATE_LIMIT_WINDOW=1m

# ==============================================================================
# DEVELOPMENT СПЕЦИФІЧНІ НАЛАШТУВАННЯ
# ==============================================================================

# Включити debug режим
DEBUG=true
DEVELOPMENT_MODE=true

# Node.js середовище для frontend
NODE_ENV=development

# ==============================================================================
# PRODUCTION СПЕЦИФІЧНІ НАЛАШТУВАННЯ (закоментовані для dev)
# ==============================================================================

# Для production встановіть:
# ATLAS_ENVIRONMENT=production
# ATLAS_NAMESPACE=atlas-mcp-prod
# DEBUG=false
# DEVELOPMENT_MODE=false
# NODE_ENV=production

# Production репліки:
# ATLAS_CORE_REPLICAS=3
# ATLAS_FRONTEND_REPLICAS=5

# Production ресурси:
# ATLAS_CORE_CPU_REQUEST=500m
# ATLAS_CORE_MEMORY_REQUEST=1Gi
# ATLAS_CORE_CPU_LIMIT=2000m
# ATLAS_CORE_MEMORY_LIMIT=4Gi

# Production зберігання:
# ATLAS_DATA_SIZE=100Gi
# QDRANT_DATA_SIZE=200Gi
# PROMETHEUS_DATA_SIZE=100Gi

# ==============================================================================
# ДОДАТКОВІ НАЛАШТУВАННЯ
# ==============================================================================

# Включити метрики
ENABLE_METRICS=true

# Таймзона
TZ=Europe/Kiev

# Версія образів (для production)
IMAGE_TAG=latest
# IMAGE_TAG=v1.0.0
