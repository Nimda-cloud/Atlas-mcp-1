# MCP Hub Express Standalone Configuration

# Server Configuration
PORT=3050
NODE_ENV=development

# API Configuration (for integration with main system)
MCP_HUB_API_BASE=http://localhost:3002
HEAD3D_SERVER_URL=http://localhost:8099

# Feature Flags
ENABLE_TTS=true
ENABLE_VOICE_INPUT=true
ENABLE_3D_HEAD=true

# Debug
DEBUG_MODE=true
LOG_LEVEL=info
