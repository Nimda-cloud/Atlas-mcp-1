{
  "description": "Native macOS MCP stack aggregated via proxy (all services local, no containers).",
  "servers": [
    {
      "name": "applescript",
      "type": "process",
      "command": "npx",
      "args": [
        "@peakmojo/applescript-mcp",
        "--remoteHost", "127.0.0.1",
        "--remoteUser", "${MACOS_SSH_USER}",
        "--identityFile", "${MCP_STACK}/proxy/keys/macos_ed25519",
        "--strict"
      ],
      "env": {},
      "restart": true,
      "timeout": 30000
    },
    {
      "name": "automator",
      "type": "http",
      "endpoint": "http://127.0.0.1:4013/mcp",
      "namespace": "macos",
      "health": {"method": "list_tools", "intervalMs": 20000}
    },
    {
      "name": "automation",
      "type": "http",
      "endpoint": "http://127.0.0.1:4014/mcp",
      "namespace": "sys",
      "optional": true
    },
    {
      "name": "playwright",
      "type": "http",
      "endpoint": "http://127.0.0.1:4015/mcp",
      "namespace": "browser"
    },
    {
      "name": "tts",
      "type": "http",
      "endpoint": "http://127.0.0.1:4016/mcp",
      "namespace": "tts",
      "optional": true
    },
    {
      "name": "vnc_main",
      "type": "process",
      "command": "npx",
      "args": ["@hrrrsn/mcp-vnc"],
      "env": {
        "VNC_HOST": "127.0.0.1",
        "VNC_PORT": "5900"
      },
      "namespace": "vnc",
      "restart": true,
      "timeout": 40000
    },
    {
      "name": "vnc_remote2",
      "type": "process",
      "command": "npx",
      "args": ["@hrrrsn/mcp-vnc"],
      "env": {
        "VNC_HOST": "${REMOTE_VNC_HOST}",
        "VNC_PORT": "5901",
        "VNC_PASSWORD": "${REMOTE_VNC_PASSWORD}"
      },
      "namespace": "vnc2",
      "optional": true,
      "restart": true
    }
  ],
  "proxy": {
    "port": 4010,
    "host": "127.0.0.1",
    "logLevel": "info",
    "cacheListToolsMs": 60000,
    "maxConcurrentCalls": 8,
    "requestTimeoutMs": 45000
  },
  "features": {
    "auditLog": {"enabled": true, "path": "${MCP_STACK}/proxy/logs/mcp-proxy-audit.log"},
    "namespacing": true,
    "toolAlias": {
      "browser.snapshot": "page_snapshot",
      "browser.evaluate": "js_eval",
      "vnc.vnc_screenshot": "desktop_shot"
    },
    "fallback": {
      "enabled": true,
      "order": ["applescript", "automator", "browser", "vnc_main"]
    }
  }
}
