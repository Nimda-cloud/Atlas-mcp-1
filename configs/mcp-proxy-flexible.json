{
  "server": {
    "host": "127.0.0.1",
    "port": 4010,
    "cors": {
      "enabled": true,
      "origins": ["*"]
    }
  },
  "logging": {
    "level": "info",
    "file": "logs/mcp-proxy.log",
    "console": true
  },
  "clients": [
    {
      "name": "applescript",
      "description": "AppleScript automation for macOS (peakmojo)",
      "type": "stdio",
      "command": "/Users/dev/mcp-stack/applescript/start.sh",
      "args": [],
      "env": {},
      "timeout": 30,
      "restart_on_error": true,
      "namespace": "as"
    },
    {
      "name": "automator",
      "description": "macOS Automator workflows (steipete)", 
      "type": "stdio",
      "command": "/Users/dev/mcp-stack/automator/start.sh",
      "args": [],
      "env": {},
      "timeout": 30,
      "restart_on_error": true,
      "namespace": "macos"
    },
    {
      "name": "automation",
      "description": "General automation tools (ashwwwin)",
      "type": "stdio",
      "command": "/Users/dev/mcp-stack/automation/start.sh",
      "args": [],
      "env": {},
      "timeout": 30,
      "restart_on_error": true,
      "namespace": "auto"
    },
    {
      "name": "playwright",
      "description": "Browser automation via Playwright (Microsoft)",
      "type": "stdio",
      "command": "/Users/dev/mcp-stack/playwright/start.sh",
      "args": [],
      "env": {},
      "timeout": 30,
      "restart_on_error": true,
      "namespace": "browser"
    },
    {
      "name": "tts",
      "description": "Text-to-Speech service (blacktop)",
      "type": "stdio",
      "command": "/Users/dev/mcp-stack/tts/start.sh",
      "args": [],
      "env": {},
      "timeout": 30,
      "restart_on_error": true,
      "namespace": "voice"
    },
    {
      "name": "vnc",
      "description": "VNC screen capture and control (hrrrsn)",
      "type": "stdio",
      "command": "/Users/dev/mcp-stack/vnc/start.sh", 
      "args": [],
      "env": {},
      "timeout": 30,
      "restart_on_error": true,
      "namespace": "vnc"
    }
  ],
  "features": {
    "namespacing": {
      "enabled": true,
      "separator": ".",
      "prefix_enabled": true
    },
    "audit_logging": {
      "enabled": true,
      "file": "logs/audit.log",
      "include_requests": true,
      "include_responses": true
    },
    "health_checks": {
      "enabled": true,
      "interval": 30,
      "timeout": 10,
      "retries": 3
    },
    "fallback_chain": {
      "enabled": true,
      "max_retries": 2,
      "retry_delay": 1
    },
    "rate_limiting": {
      "enabled": false,
      "max_requests_per_minute": 100
    },
    "authentication": {
      "enabled": false
    }
  },
  "performance": {
    "max_concurrent_requests": 50,
    "request_timeout": 60,
    "keep_alive": true,
    "compression": true
  }
}
